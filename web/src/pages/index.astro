---
export const prerender = false;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <title>zevBot Monitor</title>
    </head>
    <body
        class="font-sans text-sm text-zinc-900 bg-white px-4 py-8 max-w-[1200px] mx-auto leading-relaxed antialiased md:px-8 md:py-16"
    >
        <header class="border-b border-zinc-200 pb-6">
            <h1 class="text-4xl font-bold tracking-tighter text-black mb-2">
                zevBot Monitor
            </h1>
            <p class="text-base text-zinc-500 max-w-2xl tracking-tight">
                Authenticate with a telephone endpoint destination sequence to
                open a persistent streaming network link layer interface
                structure.
            </p>
        </header>

        <main
            class="grid grid-cols-1 gap-8 mt-8 md:grid-cols-[320px_1fr] md:items-start"
        >
            <section class="card">
                <h2 class="card-title">Authentication Context</h2>
                <div class="flex flex-wrap gap-3 md:flex-col md:items-stretch">
                    <div class="flex-1 min-w-[260px] md:w-full">
                        <input
                            type="text"
                            id="phone"
                            placeholder="+1234567890"
                            class="input-text"
                        />
                    </div>
                    <button id="connectBtn" class="btn-primary">Connect</button>
                    <button id="disconnectBtn" class="btn-danger" disabled
                        >Disconnect</button
                    >
                </div>
            </section>

            <section>
                <div
                    class="flex items-center justify-between px-1 py-2 border-b border-zinc-100 mb-4"
                >
                    <div class="flex items-center gap-2">
                        <div class="dot" id="dot"></div>
                        <span
                            id="statusText"
                            class="text-[13px] font-medium text-zinc-700"
                            >Disconnected</span
                        >
                    </div>
                    <span
                        id="countLabel"
                        class="text-xs font-medium bg-zinc-100 text-zinc-700 px-2 py-0.5 rounded border border-zinc-200"
                        >0 events</span
                    >
                </div>

                <div
                    class="border border-zinc-200 rounded-xl overflow-hidden shadow-sm bg-white"
                >
                    <div
                        class="flex items-center justify-between px-4 py-3 bg-zinc-50 border-b border-zinc-200"
                    >
                        <span class="card-title" style="margin-bottom:0"
                            >Execution Log Stream</span
                        >
                        <div class="flex gap-2">
                            <button
                                id="autoscrollBtn"
                                class="btn h-7 px-3 text-xs rounded"
                                aria-pressed="true"
                                title="Toggle autoscroll"
                            >
                                <svg
                                    width="12"
                                    height="12"
                                    viewBox="0 0 16 16"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    aria-hidden="true"
                                >
                                    <path d="M8 3v7M5 7l3 3 3-3"></path><path
                                        d="M3 13h10"></path>
                                </svg>
                                Autoscroll
                            </button>
                            <button
                                id="clearBtn"
                                class="btn h-7 px-3 text-xs rounded"
                                title="Clear log"
                            >
                                <svg
                                    width="12"
                                    height="12"
                                    viewBox="0 0 16 16"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    aria-hidden="true"
                                >
                                    <path d="M3 4h10M6 4V3h4v1M5 4l.5 9h5l.5-9"
                                    ></path>
                                </svg>
                                Clear
                            </button>
                        </div>
                    </div>

                    <div
                        id="log"
                        class="p-4 min-h-[360px] max-h-[600px] overflow-y-auto bg-white font-mono text-[13px] leading-relaxed"
                    >
                        <div
                            class="grid grid-cols-[75px_90px_1fr] gap-4 px-2 py-1 rounded hover:bg-zinc-50"
                        >
                            <span class="text-zinc-400 select-none"
                                >--:--:--</span
                            >
                            <span class="log-tag text-[#0070f3]">[info]</span>
                            <span
                                class="text-zinc-700 break-all whitespace-pre-wrap"
                                >Context pipeline idle. Provide a telephony
                                validation configuration matrix to spin up
                                downstream instances.</span
                            >
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <script>
            let ws: WebSocket | null = null;
            let autoscroll = true;
            let eventCount = 0;

            const log = document.getElementById("log") as HTMLDivElement;
            const dot = document.getElementById("dot") as HTMLDivElement;
            const statusText = document.getElementById(
                "statusText",
            ) as HTMLSpanElement;
            const connectBtn = document.getElementById(
                "connectBtn",
            ) as HTMLButtonElement;
            const disconnectBtn = document.getElementById(
                "disconnectBtn",
            ) as HTMLButtonElement;
            const phoneInput = document.getElementById(
                "phone",
            ) as HTMLInputElement;
            const autoscrollBtn = document.getElementById(
                "autoscrollBtn",
            ) as HTMLButtonElement;
            const clearBtn = document.getElementById(
                "clearBtn",
            ) as HTMLButtonElement;
            const countLabel = document.getElementById(
                "countLabel",
            ) as HTMLSpanElement;

            // ── Types ──────────────────────────────────────────────────────────────

            type ControlType =
                | "send_message"
                | "disconnect"
                | "logout"
                | "get_status";
            type EventType =
                | "pair_qr"
                | "pair_code"
                | "pair_success"
                | "pair_error"
                | "logged_out"
                | "disconnected"
                | "ack"
                | "connected"
                | "upstream_closed"
                | "error";

            interface EventMessage {
                type: EventType;
                id?: string;
                payload: Record<string, unknown>;
            }

            interface ControlMessage {
                type: ControlType;
                id: string;
                payload: Record<string, unknown>;
            }

            // ── Pending acks ───────────────────────────────────────────────────────

            const pending = new Map<
                string,
                { resolve: () => void; reject: (r: string) => void }
            >();

            function randomId(): string {
                return Math.random().toString(36).slice(2, 10);
            }

            function sendControl(
                type: ControlType,
                payload: Record<string, unknown> = {},
            ): Promise<void> {
                return new Promise((resolve, reject) => {
                    if (!ws || ws.readyState !== WebSocket.OPEN) {
                        reject("Not connected");
                        return;
                    }
                    const id = randomId();
                    pending.set(id, { resolve, reject });
                    const msg: ControlMessage = { type, id, payload };
                    ws.send(JSON.stringify(msg));
                    setTimeout(() => {
                        if (pending.has(id)) {
                            pending.delete(id);
                            reject(`Timeout: ${id}`);
                        }
                    }, 10_000);
                });
            }

            // ── UI helpers ─────────────────────────────────────────────────────────

            autoscrollBtn.addEventListener("click", () => {
                autoscroll = !autoscroll;
                autoscrollBtn.classList.toggle("active", autoscroll);
                autoscrollBtn.setAttribute("aria-pressed", String(autoscroll));
                if (autoscroll) log.scrollTop = log.scrollHeight;
            });

            log.addEventListener("scroll", () => {
                const atBottom =
                    log.scrollHeight - log.scrollTop - log.clientHeight < 32;
                if (!atBottom && autoscroll) {
                    autoscroll = false;
                    autoscrollBtn.classList.remove("active");
                    autoscrollBtn.setAttribute("aria-pressed", "false");
                }
            });

            clearBtn.addEventListener("click", () => {
                log.innerHTML = "";
                eventCount = 0;
                countLabel.textContent = "0 events";
            });

            function ts(): string {
                return new Date().toTimeString().slice(0, 8);
            }

            const tagColors: Record<string, string> = {
                info: "text-[#0070f3]",
                warn: "text-[#f5a623]",
                err: "text-[#ee0000]",
                event: "text-[#0070f3]",
            };

            function addLog(level: string, tag: string, msg: string): void {
                eventCount++;
                countLabel.textContent = `${eventCount} event${eventCount === 1 ? "" : "s"}`;
                const color = tagColors[level] ?? "text-zinc-500";
                const entry = document.createElement("div");
                entry.className =
                    "grid grid-cols-[75px_90px_1fr] gap-4 px-2 py-1 rounded hover:bg-zinc-50 max-sm:grid-cols-1 max-sm:gap-0.5 max-sm:p-2 max-sm:border-b max-sm:border-zinc-100";
                entry.innerHTML = `
          <span class="text-zinc-400 select-none">${ts()}</span>
          <span class="log-tag ${color}">${escHtml(tag)}</span>
          <span class="text-zinc-700 break-all whitespace-pre-wrap">${escHtml(msg)}</span>
        `;
                log.appendChild(entry);
                if (autoscroll) log.scrollTop = log.scrollHeight;
            }

            function escHtml(s: string): string {
                return s
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;");
            }

            function setStatus(state: string, text: string): void {
                dot.className =
                    state === "connected"
                        ? "dot-connected"
                        : state === "connecting"
                          ? "dot-connecting"
                          : state === "error"
                            ? "dot-error"
                            : "dot";
                statusText.textContent = text;
            }

            // ── Event handler ──────────────────────────────────────────────────────

            function handleEvent(msg: EventMessage): void {
                if (msg.type === "ack" && msg.id) {
                    const p = pending.get(msg.id);
                    if (p) {
                        pending.delete(msg.id);
                        const { ok, error } = msg.payload as {
                            ok: boolean;
                            error?: string;
                        };
                        ok ? p.resolve() : p.reject(error ?? "Unknown error");
                    }
                    return;
                }

                switch (msg.type) {
                    case "connected":
                        addLog(
                            "info",
                            "[ws]",
                            `Remote agent accepted pipeline for account ${msg.payload.accountId}`,
                        );
                        break;
                    case "pair_qr":
                        addLog(
                            "event",
                            "[pair]",
                            `QR Code: ${msg.payload.code}`,
                        );
                        break;
                    case "pair_code": {
                        const { code, expires_in } = msg.payload as {
                            code: string;
                            expires_in: number;
                        };
                        addLog(
                            "event",
                            "[pair]",
                            `Pair code: ${code} — expires in ${expires_in}s`,
                        );
                        break;
                    }
                    case "pair_success":
                        addLog("info", "[pair]", "Paired successfully!");
                        break;
                    case "pair_error":
                        addLog(
                            "err",
                            "[pair]",
                            `Pairing failed: ${msg.payload.reason}`,
                        );
                        break;
                    case "logged_out":
                        addLog("warn", "[session]", "Session logged out.");
                        break;
                    case "disconnected":
                        addLog("warn", "[session]", "Bot disconnected.");
                        break;
                    case "upstream_closed":
                        addLog(
                            "warn",
                            "[ws]",
                            "Upstream node closed the pipeline.",
                        );
                        break;
                    case "error":
                        addLog(
                            "err",
                            "[error]",
                            String(msg.payload.message ?? "Unknown error"),
                        );
                        break;
                    default:
                        addLog(
                            "event",
                            "[event]",
                            JSON.stringify(msg, null, 2),
                        );
                }
            }

            // ── Connect ────────────────────────────────────────────────────────────

            connectBtn.addEventListener("click", async () => {
                const phone = phoneInput.value.trim();
                if (!phone) {
                    addLog("err", "[error]", "Phone number is required.");
                    return;
                }

                connectBtn.disabled = true;
                setStatus("connecting", "Authenticating...");
                addLog("info", "[auth]", "Reaching setup endpoint...");

                let data: {
                    token: string;
                    user: { email: string; id: string };
                    account: { id: string; phone: string };
                };

                try {
                    const res = await fetch("/api/setup", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ phone }),
                    });
                    data = await res.json();
                    if (!res.ok) {
                        const err = data as any;
                        addLog(
                            "err",
                            "[error]",
                            err.error +
                                (err.detail
                                    ? " — " + JSON.stringify(err.detail)
                                    : ""),
                        );
                        setStatus("error", "Setup failed");
                        connectBtn.disabled = false;
                        return;
                    }
                } catch (e) {
                    addLog(
                        "err",
                        "[error]",
                        "Setup failed: " +
                            (e instanceof Error ? e.message : String(e)),
                    );
                    setStatus("error", "Setup failed");
                    connectBtn.disabled = false;
                    return;
                }

                const { token, user, account } = data;
                addLog(
                    "info",
                    "[auth]",
                    `Authenticated: ${user.email} (${user.id})`,
                );
                addLog(
                    "info",
                    "[accounts]",
                    `Account: ${account.id} — ${account.phone}`,
                );
                addLog(
                    "info",
                    "[ws]",
                    `Connecting to account ${account.id}...`,
                );
                setStatus("connecting", "Connecting...");

                ws = new WebSocket(
                    `ws://${window.location.hostname}:4322?accountId=${account.id}&token=${token}`,
                );

                ws.onopen = () => {
                    addLog("info", "[ws]", "WebSocket connected.");
                    setStatus("connected", `Connected — ${account.phone}`);
                    disconnectBtn.disabled = false;
                };

                ws.onmessage = (e: MessageEvent) => {
                    try {
                        const msg: EventMessage = JSON.parse(e.data as string);
                        handleEvent(msg);
                    } catch {
                        addLog(
                            "event",
                            "[event]",
                            "Unparseable message: " + String(e.data),
                        );
                    }
                };

                ws.onclose = (e: CloseEvent) => {
                    addLog(
                        "info",
                        "[ws]",
                        `Disconnected: ${e.code} ${e.reason}`,
                    );
                    setStatus("", "Disconnected");
                    connectBtn.disabled = false;
                    disconnectBtn.disabled = true;
                    ws = null;
                };

                ws.onerror = () => {
                    addLog("err", "[ws]", "WebSocket error.");
                    setStatus("error", "Connection error");
                };
            });

            disconnectBtn.addEventListener("click", () =>
                ws?.close(1000, "User disconnected"),
            );
        </script>
    </body>
</html>
