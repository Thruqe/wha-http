{
    "name": "WHA-HTTP",
    "image": "golang:latest",
    "containerEnv": {
        "RPM_BIN": "/usr/local/bin/rpm",
        "ZEVBOT_BIN": "/usr/local/bin/zevBot"
    },
    "features": {
        "ghcr.io/devcontainers/features/go:1": {
            "version": "latest"
        },
        "ghcr.io/devcontainers/features/node:1": {
            "version": "24"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "golang.go",
                "esbenp.prettier-vscode",
                "yy0931.vscode-sqlite3-editor",
                "tamasfe.even-better-toml",
                "svelte.svelte-vscode"
            ],
            "settings": {
                "editor.formatOnSave": true,
                "editor.defaultFormatter": "esbenp.prettier-vscode",
                "[go]": {
                    "editor.defaultFormatter": "golang.go",
                    "editor.formatOnSave": true,
                    "editor.codeActionsOnSave": {
                        "source.organizeImports": "explicit"
                    }
                },
                "[svelte]": {
                    "editor.defaultFormatter": "svelte.svelte-vscode"
                },
                "[toml]": {
                    "editor.defaultFormatter": "tamasfe.even-better-toml"
                },
                "[json]": {
                    "editor.defaultFormatter": "esbenp.prettier-vscode"
                },
                "[jsonc]": {
                    "editor.defaultFormatter": "esbenp.prettier-vscode"
                },
                "prettier.semi": false,
                "prettier.singleQuote": true,
                "prettier.printWidth": 100,
                "prettier.trailingComma": "es5",
                "svelte.enable-ts-plugin": true
            }
        }
    },
    "postCreateCommand": "apt-get update && apt-get install -y wget curl jq tree && go install github.com/air-verse/air@latest && wget -O /usr/local/bin/rpm https://github.com/zevlion/rpm/releases/download/latest/rpm && chmod +x /usr/local/bin/rpm && wget -qO- https://github.com/zevlion/zevBot/releases/download/alpha/zevBot-linux-amd64.tar.gz | tar -xz -C /usr/local/bin/ && chmod +x /usr/local/bin/zevBot && cd frontend && npm install"
}